<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance History | Attendify</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <style>
        .history-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 24px;
        }

        .subject-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px;
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            gap: 16px;
            box-shadow: var(--shadow-sm);
        }

        .subject-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow);
            border-color: var(--primary);
        }

        .subject-info h3 {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 4px;
            color: var(--text);
        }

        .subject-info p {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 600;
        }

        .subject-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            padding: 16px;
            background: var(--surface-2);
            border-radius: var(--radius);
        }

        .stat-item {
            text-align: center;
        }

        .stat-item span {
            display: block;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .stat-item strong {
            font-size: 18px;
            font-weight: 800;
            color: var(--text);
        }

        .stat-item.active strong {
            color: var(--primary);
        }

        .percentage-bar-wrap {
            width: 100%;
            height: 8px;
            background: #e2e8f0;
            border-radius: 99px;
            overflow: hidden;
            margin-top: 8px;
        }

        .percentage-bar {
            height: 100%;
            border-radius: 99px;
            transition: width 1s ease-out;
        }

        .bar-high {
            background: var(--success);
        }

        .bar-mid {
            background: var(--warning);
        }

        .bar-low {
            background: var(--danger);
        }

        .card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 8px;
        }

        .percentage-badge {
            font-size: 14px;
            font-weight: 800;
            padding: 4px 10px;
            border-radius: 999px;
        }

        .badge-high {
            background: #d1fae5;
            color: var(--success);
        }

        .badge-mid {
            background: #fef3c7;
            color: var(--warning);
        }

        .badge-low {
            background: #fee2e2;
            color: var(--danger);
        }

        .overall-summary {
            background: linear-gradient(135deg, var(--primary), #6366f1);
            color: #fff;
            border-radius: var(--radius-xl);
            padding: 32px;
            margin-bottom: 32px;
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 40px;
            align-items: center;
            box-shadow: var(--shadow-lg);
        }

        .overall-donut-wrap {
            display: flex;
            justify-content: center;
        }

        .overall-stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .overall-stat-box h4 {
            font-size: 14px;
            opacity: 0.8;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .overall-stat-box strong {
            font-size: 32px;
            font-weight: 800;
        }

        .no-data {
            text-align: center;
            padding: 64px 0;
            color: var(--text-muted);
        }

        .student-shell {
            grid-template-columns: 280px 1fr;
        }

        .student-main {
            max-width: none;
            width: 100%;
        }

        .timeline-section {
            margin-bottom: 48px;
        }

        .timeline-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .month-selector {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 24px;
            font-weight: 800;
            color: var(--text);
            cursor: pointer;
        }

        .timeline-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .session-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: var(--transition);
            box-shadow: var(--shadow-sm);
        }

        .session-card:hover {
            box-shadow: var(--shadow);
            transform: translateY(-2px);
        }

        .session-content {
            padding: 20px 24px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .session-main h3 {
            font-size: 17px;
            font-weight: 700;
            margin: 8px 0 4px;
        }

        .session-type {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .session-type i {
            color: var(--primary);
        }

        .session-time {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-muted);
        }

        .status-bar {
            width: 100%;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 14px;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        .status-bar.present {
            background: #e0e7ff;
            color: var(--primary);
        }

        .status-bar.absent {
            background: #fee2e2;
            color: var(--danger);
        }

        .status-bar.live {
            background: var(--primary);
            color: #fff;
            cursor: pointer;
        }

        .status-bar.live:hover {
            background: var(--primary-dark);
        }

        .no-data i {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        @media (max-width: 768px) {
            .overall-summary {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 32px;
            }

            .overall-stats-row {
                gap: 16px;
            }

            .overall-stat-box strong {
                font-size: 24px;
            }
        }
    </style>
</head>

<body>

    <div class="student-shell">

        <!-- LEFT SIDEBAR -->
        <aside class="student-menu">
            <div class="student-greeting">
                <div class="wave">
                    <i class="fa-solid fa-hand"></i>
                </div>
                <h2>History</h2>
            </div>

            <nav class="student-nav">
                <a href="/student/dashboard" class="nav-item">
                    <i class="fa-solid fa-house"></i>
                    Home
                </a>

                <a href="/student/schedule" class="nav-item">
                    <i class="fa-solid fa-calendar-days"></i>
                    Schedule
                </a>

                <a class="nav-item">
                    <i class="fa-solid fa-users"></i>
                    Community
                </a>

                <a href="/student/attendance-history" class="nav-item active">
                    <i class="fa-solid fa-chart-simple"></i>
                    My Attendance
                </a>

                <a class="nav-item">
                    <i class="fa-solid fa-book-open"></i>
                    My Courses
                </a>
            </nav>

            <div class="student-nav gap-top">
                <form action="/logout" method="POST">
                    <button class="nav-item logout-item" type="submit"
                        style="width: 100%; text-align: left; background: none; border: none; cursor: pointer;">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i>
                        Log Out
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="student-main">
            <header class="student-topbar">
                <div class="back-title">
                    <a href="/student/dashboard" class="icon-btn" aria-label="Back"><i
                            class="fa-solid fa-arrow-left"></i></a>
                    <div>
                        <span class="page-eyebrow">Analysis</span>
                        <h1>Attendance History</h1>
                    </div>
                </div>
                <div class="topbar-actions">
                    <span class="date-chip"><i class="fa-regular fa-calendar"></i>
                        <%= today %>
                    </span>
                </div>
            </header>

            <section class="overall-summary animate-in" style="width: 100%;">
                <div class="overall-donut-wrap">
                    <div class="donut"
                        style="--percent:<%= stats.overallPercentage %>; --size: 140px; --thickness: 12px; --color: #fff; --bg-donut: rgba(255,255,255,0.2);">
                        <div style="color: #fff;">
                            <strong style="font-size: 28px;">
                                <%= stats.overallPercentage %>%
                            </strong>
                            <span
                                style="font-size: 11px; opacity: 0.8; text-transform: uppercase; font-weight: 700;">Overall</span>
                        </div>
                    </div>
                </div>

                <div class="overall-stats-content">
                    <div class="overall-stats-row">
                        <div class="overall-stat-box">
                            <h4>Total Classes</h4>
                            <strong>
                                <%= stats.totalSessions %>
                            </strong>
                        </div>
                        <div class="overall-stat-box">
                            <h4>Present</h4>
                            <strong>
                                <%= stats.totalPresent %>
                            </strong>
                        </div>
                        <div class="overall-stat-box">
                            <h4>Absent</h4>
                            <strong>
                                <%= stats.totalAbsent %>
                            </strong>
                        </div>
                    </div>
                    <p style="margin-top: 20px; font-size: 14px; opacity: 0.9;">
                        Your attendance is calculated based on <%= stats.totalSessions %> sessions conducted for <%=
                                student.classGroup.name %>.
                    </p>
                </div>
            </section>

            <section class="timeline-section animate-in">
                <div class="timeline-header">
                    <div class="month-selector">
                        <%= new Date().toLocaleString('default', { month: 'long' }) %>
                            <i class="fa-solid fa-angle-down" style="font-size: 16px; margin-left: 8px;"></i>
                    </div>
                    <div class="timeline-actions" style="display: flex; gap: 12px; align-items: center;">
                        <button class="icon-btn"
                            style="background: var(--surface); border: 1px solid var(--border); width: 44px; height: 44px; border-radius: 12px;"><i
                                class="fa-solid fa-rotate-right"></i></button>
                        <div
                            style="background: var(--surface); border: 1px solid var(--border); padding: 0 16px; height: 44px; display: flex; align-items: center; border-radius: 12px; font-weight: 800; font-size: 15px;">
                            <%= new Date().getDate() %>
                        </div>
                    </div>
                </div>

                <div class="timeline-grid">
                    <% if (timeline && timeline.length> 0) { %>
                        <% timeline.forEach(function(session) { %>
                            <div class="session-card">
                                <div class="session-content">
                                    <div class="session-main">
                                        <span class="session-type">
                                            <i class="fa-solid fa-graduation-cap"></i>
                                            Core Subject
                                        </span>
                                        <h3>
                                            <%= session.subject.subjectName %>
                                        </h3>
                                        <p style="font-size: 12px; color: var(--text-muted); font-weight: 600;">Core •
                                            <%= student.classGroup.name %>
                                        </p>
                                    </div>
                                    <div class="session-time">
                                        <%= session.startTime %> - <%= session.endTime %>
                                    </div>
                                </div>

                                <% if (session.status==='PRESENT' || session.status==='LATE' ) { %>
                                    <div class="status-bar present">
                                        <i class="fa-solid fa-circle-check"></i>
                                        Marked Present
                                    </div>
                                    <% } else if (session.status==='ABSENT' ) { %>
                                        <div class="status-bar absent">
                                            <i class="fa-solid fa-circle-xmark"></i>
                                            Marked Absent
                                        </div>
                                        <% } else if (session.status==='LIVE' ) { %>
                                            <div class="status-bar live"
                                                onclick="window.location.href='/student/dashboard'">
                                                <i class="fa-solid fa-circle-play"></i>
                                                Mark Attendance
                                            </div>
                                            <% } %>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="no-data"
                                        style="background: var(--surface); border-radius: var(--radius-lg); border: 1px dashed var(--border);">
                                        <i class="fa-solid fa-calendar-day"></i>
                                        <h3>No classes for today</h3>
                                        <p>Your schedule is clear for today.</p>
                                    </div>
                                    <% } %>
                </div>
            </section>

            <div class="section-header"
                style="display: flex; justify-content: space-between; align-items: center; margin-top: 40px;">
                <h2 style="font-size: 22px; font-weight: 800;">Subject-wise Analysis</h2>
                <div class="filter-chip">
                    <i class="fa-solid fa-filter"></i> All Subjects
                    <i class="fa-solid fa-angle-down"></i>
                </div>
            </div>

            <div class="history-grid">
                <% if (subjectStats && subjectStats.length> 0) { %>
                    <% subjectStats.forEach(function(sub) { %>
                        <% let tint='mid' ; if (sub.percentage>= 75) tint = 'high';
                            else if (sub.percentage < 50) tint='low' ; %>
                                <div class="subject-card animate-in">
                                    <div class="subject-info">
                                        <h3>
                                            <%= sub.name %>
                                        </h3>
                                        <p>
                                            <%= sub.code %>
                                        </p>
                                    </div>

                                    <div class="subject-stats">
                                        <div class="stat-item">
                                            <span>Total</span>
                                            <strong>
                                                <%= sub.total %>
                                            </strong>
                                        </div>
                                        <div class="stat-item active">
                                            <span>Present</span>
                                            <strong>
                                                <%= sub.present %>
                                            </strong>
                                        </div>
                                        <div class="stat-item">
                                            <span>Absent</span>
                                            <strong>
                                                <%= sub.absent %>
                                            </strong>
                                        </div>
                                    </div>

                                    <div>
                                        <div class="card-footer">
                                            <span class="text-muted"
                                                style="font-size: 12px; font-weight: 700;">ATTENDANCE RATE</span>
                                            <span class="percentage-badge badge-<%= tint %>">
                                                <%= sub.percentage %>%
                                            </span>
                                        </div>
                                        <div class="percentage-bar-wrap">
                                            <div class="percentage-bar bar-<%= tint %>"
                                                style="--w: <%= sub.percentage %>%; width: var(--w);"></div>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div class="no-data">
                                            <i class="fa-solid fa-book-open"></i>
                                            <h3>No subjects found</h3>
                                            <p>You are not enrolled in any subjects yet.</p>
                                        </div>
                                        <% } %>
            </div>

        </main>

    </div>

</body>

</html>