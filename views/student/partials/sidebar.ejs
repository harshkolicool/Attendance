<%
    const studentFirstName =
        student && student.fullName
            ? student.fullName.split(" ")[0]
            : "Student";
%>

<aside class="ui-sidebar schedule-sidebar">
    <div class="student-welcome">
        <div class="welcome-icon">
            <i class="fa-solid fa-hand"></i>
        </div>
        <h2>Hi <%= studentFirstName %>!</h2>
    </div>

    <nav class="sidebar-menu shell-sidebar-nav">
        <a href="/student/dashboard" class="menu-item <%= activePage === 'dashboard' ? 'active' : '' %>">
            <i class="fa-solid fa-house"></i>
            <span>Dashboard</span>
        </a>

        <a href="/student/schedule" class="menu-item <%= activePage === 'schedule' ? 'active' : '' %>">
            <i class="fa-solid fa-calendar-days"></i>
            <span>Schedule</span>
        </a>

        <a href="/student/attendance-history" class="menu-item <%= activePage === 'attendance-history' ? 'active' : '' %>">
            <i class="fa-solid fa-chart-column"></i>
            <span>Attendance History</span>
        </a>

        <a href="/student/passkeys" class="menu-item <%= activePage === 'passkeys' ? 'active' : '' %>">
            <i class="fa-solid fa-fingerprint"></i>
            <span>Passkeys</span>
        </a>

        <a href="/student/notifications" class="menu-item <%= activePage === 'notifications' ? 'active' : '' %>">
            <i class="fa-solid fa-bell"></i>
            <span>Notifications</span>
            <span class="ui-notification-badge js-notification-badge"></span>
        </a>
    </nav>

    <div class="shell-sidebar-footer">
        <p class="shell-settings-label">Settings</p>

        <form action="/logout" method="POST" class="sidebar-logout-form">
            <button class="menu-link sidebar-logout-button" type="submit">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span>Log Out</span>
            </button>
        </form>
    </div>
</aside>
